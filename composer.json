{
    "name": "rushing/laravel-popcorn",
    "description": "A tiny kernel for transport-agnostic invocable capabilities and self-validating strategy ladders — local, MCP, or webhook bindings behind one named contract.",
    "keywords": ["laravel", "invocable", "strategy", "capability", "registry", "binding"],
    "license": "proprietary",
    "authors": [
        {
            "name": "Stephen Rushing",
            "email": "stephenr85@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Rushing\\Popcorn\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\Popcorn\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rushing\\Popcorn\\PopcornServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
